# ============= SERVER TYPE =============
# Options: 'java' or 'bedrock'
SERVER_TYPE=java

# ============= JAVA EDITION CONFIG =============
SERVER_HOST=localhost
SERVER_PORT=25565
MC_VERSION=1.20.1
AUTH_TYPE=offline
# AUTH_TYPE options: 'offline' or 'microsoft'

# ============= BOT CONFIGURATION =============
BOT_USERNAME=MinecraftBot

# ============= BEDROCK EDITION CONFIG =============
# Uncomment these for Bedrock Edition connection
# XBOX_USERNAME=your_email@example.com
# BOT_PASSWORD=your_app_password
# 
# For Minecraft Realms:
# USE_REALM=true
# REALM_ID=your_realm_id_here
